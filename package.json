{
  "name": "@gosper/gosper-wechat",
  "version": "0.1.0",
  "description": "Gosper WeChat transport bridge",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "gosper-wechat": "bin/gosper-wechat.ts"
  },
  "files": [
    "bin/",
    "deploy/",
    "docs/",
    "src/",
    "env.example",
    "README.md",
    "README.zh_CN.md",
    "LICENSE"
  ],
  "scripts": {
    "bridge": "tsx src/gosper-wechat-bridge.ts",
    "start": "tsx src/gosper-wechat-bridge.ts",
    "quickstart": "tsx bin/gosper-wechat.ts quickstart",
    "env": "tsx bin/gosper-wechat.ts env",
    "doctor": "tsx bin/gosper-wechat.ts doctor",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "tsx": "^4.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
