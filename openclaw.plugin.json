{
  "id": "gosper-openclaw-wechat",
  "name": "Gosper OpenClaw WeChat",
  "description": "OpenClaw WeChat transport bridge for Gosper. Uses iLink QR, getupdates, and sendmessage without registering an OpenClaw channel runtime.",
  "version": "0.1.0",
  "legacyPluginIds": [
    "gosper-openclaw-wechat-bridge"
  ],
  "activation": {
    "onStartup": false,
    "onCommands": [
      "gosper-openclaw-wechat"
    ],
    "onConfigPaths": [
      "plugins.entries.gosper-openclaw-wechat"
    ]
  },
  "setup": {
    "requiresRuntime": false,
    "providers": [
      {
        "id": "gosper-openclaw-wechat",
        "authMethods": [
          "shared-secret"
        ],
        "envVars": [
          "OPENCLAW_WECHAT_BRIDGE_TOKEN",
          "OPENCLAW_WECHAT_GOSPER_BASE_URL",
          "OPENCLAW_WECHAT_GOSPER_TRIGGER_SECRET",
          "OPENCLAW_WECHAT_BRIDGE_STATE_SECRET",
          "OPENCLAW_WECHAT_BRIDGE_STATE_PATH",
          "OPENCLAW_WECHAT_ILINK_BASE_URL",
          "OPENCLAW_WECHAT_BOT_TYPE",
          "OPENCLAW_WECHAT_POLL_INTERVAL_MS",
          "OPENCLAW_WECHAT_LONG_POLL_TIMEOUT_MS"
        ]
      }
    ]
  },
  "contracts": {
    "tools": [
      "gosper_wechat_bridge_config"
    ]
  },
  "toolMetadata": {
    "gosper_wechat_bridge_config": {
      "configSignals": [
        {
          "rootPath": "plugins.entries.gosper-openclaw-wechat.config",
          "required": [
            "bridgeBaseUrl"
          ]
        }
      ]
    }
  },
  "commandAliases": [
    {
      "name": "gosper-openclaw-wechat",
      "kind": "external-cli",
      "cliCommand": "gosper-openclaw-wechat"
    }
  ],
  "providerAuthChoices": [
    {
      "provider": "gosper-openclaw-wechat",
      "method": "shared-secret",
      "choiceId": "gosper-openclaw-wechat-shared-secret",
      "choiceLabel": "Gosper WeChat bridge shared secrets",
      "groupId": "gosper-openclaw-wechat",
      "groupLabel": "Gosper WeChat",
      "optionKey": "bridgeToken",
      "cliFlag": "--bridge-token",
      "cliOption": "--bridge-token <token>",
      "cliDescription": "Bearer token used by Gosper to call the WeChat bridge.",
      "assistantVisibility": "manual-only",
      "onboardingScopes": [
        "text-inference"
      ]
    }
  ],
  "uiHints": {
    "bridgeBaseUrl": {
      "label": "Bridge public URL",
      "placeholder": "https://wechat-bridge.example.com"
    },
    "gosperBaseUrl": {
      "label": "Self-hosted Gosper public URL",
      "placeholder": "https://gosper.example.com"
    },
    "bridgeToken": {
      "label": "Bridge bearer token",
      "sensitive": true
    },
    "triggerSecret": {
      "label": "Gosper trigger secret",
      "sensitive": true
    },
    "stateSecret": {
      "label": "Bridge state encryption secret",
      "sensitive": true
    },
    "ilinkBaseUrl": {
      "label": "iLink base URL",
      "placeholder": "https://ilinkai.weixin.qq.com"
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "bridgeBaseUrl": {
        "type": "string"
      },
      "gosperBaseUrl": {
        "type": "string"
      },
      "bridgeToken": {
        "type": "string"
      },
      "triggerSecret": {
        "type": "string"
      },
      "stateSecret": {
        "type": "string"
      },
      "statePath": {
        "type": "string"
      },
      "ilinkBaseUrl": {
        "type": "string"
      },
      "botType": {
        "type": "string"
      },
      "pollIntervalMs": {
        "type": "integer",
        "minimum": 250
      },
      "longPollTimeoutMs": {
        "type": "integer",
        "minimum": 1000
      }
    }
  }
}
